# ── Telegram ──────────────────────────────────────────────────
BOT_TOKEN=7234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_USERNAME=my_vpn_bot          # без @
ADMIN_IDS=123456789              # твой Telegram ID (узнать: @userinfobot)

# ── Telegram Stars (включить: true/false) ─────────────────────
# Подключить: @BotFather → твой бот → Bot Payments → Telegram Stars
STARS_ENABLED=true

# ── Канал для авто-постов о продажах (необязательно) ──────────
# CHANNEL_ID=-1001234567890

# ── Marzban VPN Panel ─────────────────────────────────────────
MARZBAN_URL=http://localhost:8000
MARZBAN_USER=admin
MARZBAN_PASS=сильный_пароль
INBOUND_TAG=vless-in             # имя inbound в панели Marzban

# ── CryptoBot (USDT/TON/BTC) — получить: @CryptoBot → Pay → Apps
CRYPTO_TOKEN=токен_из_cryptopay

# ── YooKassa (карты, СБП) — yookassa.ru → Настройки → API ────
# Требует ИП или самозанятость. Регистрация бесплатная.
YK_SHOP_ID=123456
YK_SECRET=live_xxxxxxxxxxxxxxxxxxxx

# ── База данных ───────────────────────────────────────────────
DB_PATH=/opt/vpn-bot/vpn.db
